# Copy file này thành .env trên server (KHÔNG commit .env thật lên git):
#   cp .env.example .env
# rồi điền giá trị thật vào.

# BẮT BUỘC: chuỗi bí mật cố định để giữ phiên đăng nhập qua các lần restart/deploy.
# Sinh 1 chuỗi ngẫu nhiên, ví dụ: openssl rand -hex 32
AUTOFOTELLO_SECRET=doi-thanh-chuoi-ngau-nhien-dai-cua-ban

# BẮT BUỘC: thông tin dự án Supabase (Settings -> API trên dashboard Supabase).
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# TÙY CHỌN: bật thông báo Telegram khi có đăng ký/thanh toán (bỏ trống nếu không dùng).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
